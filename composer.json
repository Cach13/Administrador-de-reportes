{
    "name": "capital-transport/management-system",
    "description": "Sistema profesional de gestión de reportes de transporte con procesamiento PDF y generación de reportes",
    "type": "project",
    "version": "2.0.0",
    "authors": [
        {
            "name": "Capital Transport LLP",
            "email": "admin@capitaltransport.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-gd": "*",
        "ext-zip": "*",
        "ext-xml": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "phpoffice/phpspreadsheet": "^1.29",
        "smalot/pdfparser": "^2.7",
        "tecnickcom/tcpdf": "^6.6",
        "league/csv": "^9.8",
        "phpmailer/phpmailer": "^6.8",
        "monolog/monolog": "^3.5",
        "vlucas/phpdotenv": "^5.5",
        "twig/twig": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Controllers\\": "app/Controllers/",
            "App\\Services\\": "app/Services/",
            "App\\Models\\": "app/Models/",
            "App\\Repositories\\": "app/Repositories/",
            "App\\Utils\\": "app/Utils/",
            "Classes\\": "classes/"
        },
        "files": [
            "config/constants.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@setup-directories",
            "@check-permissions"
        ],
        "setup-directories": "php scripts/setup-directories.php",
        "check-permissions": "php scripts/check-permissions.php",
        "install-production": "composer install --no-dev --optimize-autoloader --no-interaction",
        "update-production": "composer update --no-dev --optimize-autoloader --no-interaction",
        "clear-cache": "rm -rf vendor/composer/cache/* storage/cache/*",
        "test": "phpunit tests/",
        "cs-fix": "phpcbf --standard=PSR12 app/ classes/",
        "cs-check": "phpcs --standard=PSR12 app/ classes/",
        "full-setup": [
            "@install-production",
            "@setup-directories",
            "@check-permissions"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform-check": false,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "archive": {
        "exclude": [
            "tests/",
            "docs/",
            "*.md",
            ".gitignore",
            ".env*",
            "storage/logs/*",
            "storage/cache/*",
            "public/uploads/*"
        ]
    },
    "extra": {
        "system-requirements": {
            "php": ">=7.4",
            "extensions": ["pdo", "gd", "zip", "xml", "mbstring", "json"],
            "memory_limit": "256M",
            "max_execution_time": "300"
        }
    }
}