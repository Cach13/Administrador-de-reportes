# ========================================
# TRANSPORT MANAGEMENT SYSTEM - ENVIRONMENT CONFIG
# ========================================

# INFORMACIÓN GENERAL DEL SISTEMA
APP_NAME="Capital Transport Management System"
APP_VERSION="2.0.0"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/transport-management

# CONFIGURACIÓN DE BASE DE DATOS
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=transport_management
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# CONFIGURACIÓN DE SESIONES
SESSION_LIFETIME=1440
SESSION_NAME=transport_session
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# CONFIGURACIÓN DE ARCHIVOS
UPLOAD_MAX_SIZE=20971520
UPLOAD_ALLOWED_TYPES=pdf,xlsx,xls
UPLOAD_PATH=public/uploads
REPORTS_PATH=public/uploads/reports
TEMP_PATH=storage/temp
BACKUP_PATH=storage/backup

# CONFIGURACIÓN DE LOGGING
LOG_LEVEL=info
LOG_PATH=storage/logs
LOG_MAX_FILES=30
LOG_MAX_SIZE=10485760

# CONFIGURACIÓN DE EMAIL (PHPMAILER)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@capitaltransport.com
MAIL_FROM_NAME="Capital Transport System"

# CONFIGURACIÓN DE SEGURIDAD
HASH_ALGORITHM=PASSWORD_DEFAULT
ENCRYPTION_KEY=your-32-character-secret-key-here
JWT_SECRET=your-jwt-secret-key-here
CSRF_TOKEN_EXPIRY=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# CONFIGURACIÓN DE PROCESAMIENTO
PROCESSING_TIMEOUT=300
MAX_CONCURRENT_PROCESSES=3
QUALITY_THRESHOLD=0.75
AUTO_PROCESS_FILES=false
BACKUP_ORIGINAL_FILES=true

# CONFIGURACIÓN DE CACHE
CACHE_DRIVER=file
CACHE_PATH=storage/cache
CACHE_DEFAULT_TTL=3600

# CONFIGURACIÓN DE REPORTES
REPORT_DEFAULT_FORMAT=pdf
REPORT_INCLUDE_CHARTS=true
REPORT_AUTO_EMAIL=false
REPORT_COMPANY_LOGO=public/assets/img/logo.png

# CONFIGURACIÓN DE API
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=60
API_TIMEOUT=30

# CONFIGURACIÓN DE TIMEZONE
TIMEZONE=America/Mexico_City

# CONFIGURACIÓN DE DESARROLLO (solo si APP_ENV=development)
DEV_SHOW_ERRORS=true
DEV_LOG_QUERIES=false
DEV_CACHE_DISABLE=false