-- 8. VISTAS ÚTILES (SOLO LAS NECESARIAS)
-- ========================================

-- Vista de resumen por empresa (SIMPLIFICADA)
CREATE VIEW company_summary AS
SELECT 
    c.id,
    c.name,
    c.identifier,
    c.capital_percentage,
    c.current_payment_no,
    COUNT(DISTINCT v.id) as total_vouchers_processed,
    COUNT(DISTINCT t.id) as total_trips_extracted,
    COUNT(DISTINCT r.id) as total_reports_generated,
    COALESCE(SUM(r.total_payment), 0) as total_payments_made,
    COALESCE(SUM(r.capital_deduction), 0) as total_capital_deductions,
    MAX(r.payment_date) as last_payment_date
FROM companies c
LEFT JOIN trips t ON c.id = t.company_id
LEFT JOIN vouchers v ON t.voucher_id = v.id
LEFT JOIN reports r ON c.id = r.company_id
WHERE c.is_active = 1
GROUP BY c.id, c.name, c.identifier, c.capital_percentage, c.current_payment_no;

-- Vista de estadísticas de vouchers (SIMPLIFICADA)
CREATE VIEW voucher_stats AS
SELECT 
    v.id,
    v.voucher_number,
    v.original_filename,
    v.status,
    v.total_rows_found,
    v.valid_rows_extracted,
    v.extraction_confidence,
    COUNT(DISTINCT t.company_id) as companies_found,
    COUNT(t.id) as total_trips,
    COALESCE(SUM(t.amount), 0) as total_amount
FROM vouchers v
LEFT JOIN trips t ON v.id = t.voucher_id
GROUP BY v.id, v.voucher_number, v.original_filename, v.status, 
         v.total_rows_found, v.valid_rows_extracted, v.extraction_confidence;

-- ========================================
-- 9. PROCEDIMIENTO SIMPLE PARA SIGUIENTE PAYMENT_NO
-- ========================================

DELIMITER //
CREATE PROCEDURE GetNextPaymentNumber(IN company_id INT, OUT next_payment_no INT)
BEGIN
    DECLARE current_year YEAR DEFAULT YEAR(NOW());
    DECLARE last_year YEAR;
    
    -- Obtener el último año de pago de la empresa
    SELECT last_payment_year INTO last_year 
    FROM companies 
    WHERE id = company_id;
    
    -- Si es un nuevo año, resetear el contador
    IF last_year IS NULL OR last_year < current_year THEN
        UPDATE companies 
        SET current_payment_no = 1, last_payment_year = current_year 
        WHERE id = company_id;
        SET next_payment_no = 1;
    ELSE
        -- Incrementar el contador
        UPDATE companies 
        SET current_payment_no = current_payment_no + 1 
        WHERE id = company_id;
        
        SELECT current_payment_no INTO next_payment_no 
        FROM companies 
        WHERE id = company_id;
    END IF;
END //
DELIMITER ;

