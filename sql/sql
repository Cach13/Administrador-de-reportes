-- Vista de resumen por empresa (actualizada)
CREATE VIEW company_summary AS
SELECT 
    c.id,
    c.name,
    c.identifier,
    c.capital_percentage,
    c.current_payment_no,
    COUNT(DISTINCT v.id) as total_vouchers_processed,
    COUNT(DISTINCT t.id) as total_trips_extracted,
    COUNT(DISTINCT r.id) as total_reports_generated,
    COALESCE(SUM(r.total_payment), 0) as total_payments_made,
    COALESCE(SUM(r.capital_deduction), 0) as total_capital_deductions,
    MAX(r.payment_date) as last_payment_date,
    COUNT(DISTINCT u.id) as assigned_users           -- 🆕 Usuarios asignados a la empresa
FROM companies c
LEFT JOIN trips t ON c.id = t.company_id
LEFT JOIN vouchers v ON t.voucher_id = v.id
LEFT JOIN reports r ON c.id = r.company_id
LEFT JOIN users u ON c.id = u.company_id            -- 🆕 JOIN con usuarios
WHERE c.is_active = 1
GROUP BY c.id, c.name, c.identifier, c.capital_percentage, c.current_payment_no;

-- Vista de estadísticas de vouchers (mantenida)
CREATE VIEW voucher_stats AS
SELECT 
    v.id,
    v.voucher_number,
    v.original_filename,
    v.status,
    v.total_rows_found,
    v.valid_rows_extracted,
    v.extraction_confidence,
    COUNT(DISTINCT t.company_id) as companies_found,
    COUNT(t.id) as total_trips,
    COALESCE(SUM(t.amount), 0) as total_amount,
    u.full_name as uploaded_by_name
FROM vouchers v
LEFT JOIN trips t ON v.id = t.voucher_id
LEFT JOIN users u ON v.uploaded_by = u.id
GROUP BY v.id, v.voucher_number, v.original_filename, v.status, 
         v.total_rows_found, v.valid_rows_extracted, v.extraction_confidence, u.full_name;

-- 🆕 Vista de usuarios activos (para AuthService)
CREATE VIEW active_users_view AS
SELECT 
    u.id,
    u.username,
    u.email,
    u.full_name,
    u.role,
    u.last_login,
    u.last_activity,
    u.login_count,
    c.name as company_name,
    c.identifier as company_identifier,
    CASE 
        WHEN u.last_activity > DATE_SUB(NOW(), INTERVAL 30 MINUTE) THEN 'Online'
        WHEN u.last_activity > DATE_SUB(NOW(), INTERVAL 24 HOUR) THEN 'Recent'
        ELSE 'Offline'
    END as status
FROM users u
LEFT JOIN companies c ON u.company_id = c.id
WHERE u.is_active = 1
ORDER BY u.last_activity DESC;

-- 🆕 Vista de estadísticas de login (para AuthService)
CREATE VIEW login_stats_view AS
SELECT 
    DATE(al.created_at) as date,
    COUNT(CASE WHEN al.action = 'AUTH_SUCCESS' THEN 1 END) as successful_logins,
    COUNT(CASE WHEN al.action = 'AUTH_FAILED' THEN 1 END) as failed_logins,
    COUNT(DISTINCT al.user_id) as unique_users,
    COUNT(DISTINCT al.ip_address) as unique_ips
FROM audit_log al
WHERE al.action IN ('AUTH_SUCCESS', 'AUTH_FAILED')
  AND al.created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY)
GROUP BY DATE(al.created_at)
ORDER BY date DESC;

