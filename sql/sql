-- Procedimiento para limpiar datos antiguos
DELIMITER //
CREATE PROCEDURE CleanupAuthData()
BEGIN
    -- Limpiar intentos de login antiguos (más de 24 horas)
    DELETE FROM login_attempts 
    WHERE last_attempt < DATE_SUB(NOW(), INTERVAL 24 HOUR);
    
    -- Limpiar tokens expirados
    DELETE FROM remember_tokens 
    WHERE expires_at < NOW();
    
    -- Limpiar logs de auditoría antiguos (más de 6 meses)
    DELETE FROM audit_log 
    WHERE created_at < DATE_SUB(NOW(), INTERVAL 6 MONTH);
    
    -- Limpiar activity_logs antiguos (más de 3 meses)
    DELETE FROM activity_logs 
    WHERE created_at < DATE_SUB(NOW(), INTERVAL 3 MONTH);
    
    SELECT 
        'Limpieza completada' as status,
        ROW_COUNT() as records_deleted,
        NOW() as timestamp;
END //
DELIMITER ;

-- 🆕 Procedimiento para actualizar payment_no por empresa
DELIMITER //
CREATE PROCEDURE GetNextPaymentNumber(IN company_id INT, OUT next_payment_no INT)
BEGIN
    DECLARE current_year YEAR DEFAULT YEAR(NOW());
    DECLARE last_year YEAR;
    
    -- Obtener el último año de pago de la empresa
    SELECT last_payment_year INTO last_year 
    FROM companies 
    WHERE id = company_id;
    
    -- Si es un nuevo año, resetear el contador
    IF last_year IS NULL OR last_year < current_year THEN
        UPDATE companies 
        SET current_payment_no = 1, last_payment_year = current_year 
        WHERE id = company_id;
        SET next_payment_no = 1;
    ELSE
        -- Incrementar el contador
        UPDATE companies 
        SET current_payment_no = current_payment_no + 1 
        WHERE id = company_id;
        
        SELECT current_payment_no INTO next_payment_no 
        FROM companies 
        WHERE id = company_id;
    END IF;
END //
DELIMITER ;

