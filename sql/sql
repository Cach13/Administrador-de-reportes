-- ========================================
-- 1. TABLA DE EMPRESAS (CREAR PRIMERO - SIN FOREIGN KEYS)
-- ========================================
CREATE TABLE companies (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(150) NOT NULL,
    identifier VARCHAR(3) UNIQUE NOT NULL,           -- JAV, ABC, etc. (chars 4-6 del Vehicle ID)
    legal_name VARCHAR(200) NULL,
    tax_id VARCHAR(50) NULL,
    contact_person VARCHAR(100) NULL,
    phone VARCHAR(20) NULL,
    email VARCHAR(100) NULL,
    address TEXT NULL,
    city VARCHAR(100) NULL,
    state VARCHAR(100) NULL,
    postal_code VARCHAR(10) NULL,
    country VARCHAR(50) DEFAULT 'México',
    
    -- CONFIGURACIÓN CAPITAL TRANSPORT
    capital_percentage DECIMAL(5,2) DEFAULT 5.00,   -- Variable por empresa (ej: 5%)
    current_payment_no INT DEFAULT 1,               -- Auto-increment por empresa
    last_payment_year YEAR DEFAULT NULL,            -- Para reset anual
    
    -- Configuración bancaria
    bank_name VARCHAR(100) NULL,
    account_number VARCHAR(50) NULL,
    clabe VARCHAR(18) NULL,
    
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    created_by INT NULL,                             -- 🔄 SIN FOREIGN KEY por ahora
    is_active BOOLEAN DEFAULT TRUE,
    
    -- Índices (sin foreign keys por ahora)
    INDEX idx_name (name),
    INDEX idx_identifier (identifier),               -- Para búsquedas rápidas
    INDEX idx_tax_id (tax_id),
    INDEX idx_active (is_active)
);

-- ========================================
-- 2. TABLA DE USUARIOS (CREAR DESPUÉS DE COMPANIES)
-- ========================================
CREATE TABLE users (
    id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,                 -- 🔄 CAMBIADO: 'password' en lugar de 'password_hash' (AuthService)
    full_name VARCHAR(100) NOT NULL,
    role ENUM('admin', 'manager', 'operator') DEFAULT 'operator',  -- 🆕 AGREGADO: 'manager' para más granularidad
    company_id INT NULL,                            -- 🆕 AGREGADO: Usuarios pueden pertenecer a una empresa específica
    avatar VARCHAR(255) NULL,
    phone VARCHAR(20) NULL,
    
    -- 🆕 CAMPOS AUTHSERVICE
    login_count INT DEFAULT 0,                      -- Contador de logins
    last_activity TIMESTAMP NULL,                   -- Última actividad (AuthService)
    password_changed_at TIMESTAMP NULL,             -- Cuándo cambió password
    created_by INT NULL,                            -- Quién creó el usuario
    updated_by INT NULL,                            -- Quién lo actualizó
    
    -- Campos originales mantenidos
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    last_login TIMESTAMP NULL,
    is_active BOOLEAN DEFAULT TRUE,
    failed_login_attempts INT DEFAULT 0,            -- Compatible con login_attempts table
    locked_until TIMESTAMP NULL,
    
    -- 🔄 CLAVES FORÁNEAS (solo company_id por ahora, self-references después)
    FOREIGN KEY (company_id) REFERENCES companies(id) ON DELETE SET NULL,
    
    -- Índices optimizados
    INDEX idx_username (username),
    INDEX idx_email (email),
    INDEX idx_role (role),
    INDEX idx_active (is_active),
    INDEX idx_company (company_id),                 -- 🆕 Para filtros por empresa
    INDEX idx_last_activity (last_activity)         -- 🆕 Para AuthService
);
